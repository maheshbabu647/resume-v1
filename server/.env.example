# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/careerforge

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_16_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_16_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: http://localhost:4000/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback

# ─── Google AI (Gemini) ───────────────────────────────────────────────────────
# Create at: aistudio.google.com/app/apikey  (or via Google Cloud AI Platform)
GEMINI_API_KEY=

# ─── Google Cloud Storage ─────────────────────────────────────────────────────
# Create bucket at: console.cloud.google.com → Cloud Storage
# GCS_PROJECT_ID  — your GCP project ID (e.g. careerforge-prod)
# GCS_BUCKET_NAME — your bucket name   (e.g. careerforge-exports)
# GCS_PUBLIC_URL  — base URL for public objects (e.g. https://storage.googleapis.com/careerforge-exports)
# GCS_KEY_FILE    — LOCAL DEV ONLY: path to service account JSON
#                   In Cloud Run, leave blank — ADC is used automatically.
GCS_PROJECT_ID=
GCS_BUCKET_NAME=careerforge-exports
GCS_PUBLIC_URL=https://storage.googleapis.com/careerforge-exports
GCS_KEY_FILE=

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Dashboard: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
